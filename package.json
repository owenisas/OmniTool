{
  "name": "omnitool",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@omnitool/web",
    "dev:desktop": "turbo run dev --filter=@omnitool/desktop",
    "build:desktop": "turbo run build --filter=@omnitool/desktop",
    "build:desktop:signed": "./scripts/build-desktop-macos-signed.sh",
    "ship:desktop": "osascript -e 'quit app \"OmniTool\"' 2>/dev/null; for v in /Volumes/OmniTool*; do hdiutil detach \"$v\" -force -quiet 2>/dev/null; done; pnpm build:desktop && DMG=apps/desktop/src-tauri/target/release/bundle/dmg/OmniTool_0.0.1_aarch64.dmg && MNT=$(hdiutil attach \"$DMG\" -nobrowse -noautoopen -plist | plutil -extract \"system-entities\".0.\"mount-point\" raw -) && rm -rf /Applications/OmniTool.app && cp -R \"$MNT/OmniTool.app\" /Applications/ && hdiutil detach \"$MNT\" -quiet && rm -rf ~/Library/Caches/dev.omnitool.app/WebKit ~/Library/Caches/omnitool-desktop/WebKit && open -a OmniTool",
    "lint": "turbo run lint",
    "db:push": "turbo run db:push --filter=@omnitool/database",
    "db:migrate": "turbo run db:migrate --filter=@omnitool/database",
    "db:deploy": "turbo run db:deploy --filter=@omnitool/database",
    "db:seed": "turbo run db:seed --filter=@omnitool/database",
    "db:studio": "turbo run db:studio --filter=@omnitool/database",
    "db:generate": "turbo run db:generate --filter=@omnitool/database",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "ai": "^4.3.19",
      "@ai-sdk/openai": "^1.3.24",
      "@ai-sdk/anthropic": "^1.2.12",
      "@ai-sdk/provider": "^1.1.3",
      "@ai-sdk/provider-utils": "^2.2.8",
      "@ai-sdk/react": "^1.2.12",
      "@ai-sdk/ui-utils": "^1.2.11"
    }
  },
  "dependencies": {
    "react-resizable-panels": "^4.11.0"
  }
}
