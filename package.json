{
  "name": "omnitool",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@omnitool/web",
    "dev:desktop": "turbo run dev --filter=@omnitool/desktop",
    "build:desktop": "turbo run build --filter=@omnitool/desktop",
    "lint": "turbo run lint",
    "db:push": "turbo run db:push --filter=@omnitool/database",
    "db:migrate": "turbo run db:migrate --filter=@omnitool/database",
    "db:deploy": "turbo run db:deploy --filter=@omnitool/database",
    "db:seed": "turbo run db:seed --filter=@omnitool/database",
    "db:studio": "turbo run db:studio --filter=@omnitool/database",
    "db:generate": "turbo run db:generate --filter=@omnitool/database",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp"
    ]
  },
  "dependencies": {
    "react-resizable-panels": "^4.11.0"
  }
}
