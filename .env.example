# Database
DATABASE_URL=***REMOVED***
DIRECT_URL=***REMOVED***

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Auth
AUTH_SECRET=***REMOVED***
AUTH_URL="http://localhost:3000"
# OAuth callback URLs are built automatically as: ${AUTH_URL}/api/integrations/{provider}/callback
# No separate redirect URI env vars needed — just set AUTH_URL to your production domain.

# App URLs
# Set NEXT_PUBLIC_OMNITOOL_API_URL when a static desktop/PWA shell needs to call a hosted backend.
NEXT_PUBLIC_OMNITOOL_API_URL=""
# Used by the bundled desktop app (static redirect shell) when OMNITOOL_DESKTOP_URL is unset
NEXT_PUBLIC_OMNITOOL_WEB_URL="http://localhost:3000"
# Optional override for `pnpm build:desktop` / Tauri beforeBuild redirect target (defaults to NEXT_PUBLIC_OMNITOOL_WEB_URL, then AUTH_URL)
OMNITOOL_DESKTOP_URL=""
# Optional; shown on Settings → About (e.g. CI inject at build time)
NEXT_PUBLIC_APP_VERSION=""

# Scheduled jobs
# Required in production for Vercel Cron requests.
CRON_SECRET=""

# Local-first sync (PowerSync). Web/Desktop clients replicate listed tables into wa-sqlite when configured.
# 1) Run a PowerSync Service against this Postgres database; upload `infra/powersync/sync-rules.yaml`.
# 2) In the PowerSync dashboard, configure custom JWT auth: HS256, same secret as POWERSYNC_TOKEN_SECRET,
#    `kid` matching POWERSYNC_JWT_KID, audience = POWERSYNC_URL (this instance URL).
# 3) pnpm --filter @omnitool/web exec powersync-web copy-assets -o apps/web/public
POWERSYNC_URL=""
POWERSYNC_JWT_KID="omnitool"
POWERSYNC_TOKEN_SECRET=***REMOVED***

# AI — NVIDIA NIM (OpenAI-compatible, https://build.nvidia.com/models )
NVIDIA_API_KEY=""
# Optional; defaults to NVIDIA integrate gateway /v1 (see NVIDIA docs if your model uses another host)
NVIDIA_NIM_BASE_URL="https://integrate.api.nvidia.com/v1"
# Model slug from the Build portal (example below may vary by account)
NVIDIA_NIM_MODEL="meta/llama-3.1-8b-instruct"

# AI — Anthropic (used when NVIDIA_API_KEY is unset)
ANTHROPIC_API_KEY=***REMOVED***
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"

# Legacy name kept for reference; prefer NVIDIA_API_KEY + NVIDIA_NIM_* above.
OPENAI_API_KEY=***REMOVED***

# Integrations - Token Encryption
INTEGRATION_ENCRYPTION_KEY=***REMOVED***

# GitHub App
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_WEBHOOK_SECRET=""

# Supabase Auth - GitHub social login
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=""
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=""

# Notion
NOTION_CLIENT_ID=""
NOTION_CLIENT_SECRET=""

# Slack
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_SIGNING_SECRET=""
SLACK_BOT_TOKEN=""

# Linear
LINEAR_CLIENT_ID=""
LINEAR_CLIENT_SECRET=""
LINEAR_WEBHOOK_SECRET=""

# Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Jira
JIRA_CLIENT_ID=""
JIRA_CLIENT_SECRET=""

# Figma
FIGMA_CLIENT_ID=""
FIGMA_CLIENT_SECRET=""

# Discord
DISCORD_BOT_TOKEN=""

# Rate Limiting (Upstash Redis — optional, rate limiting disabled when unset)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# macOS desktop signing (shell exports / CI only — not read by Next.js)
# Use a "Developer ID Application" identity for DMG distribution outside the App Store.
# APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"
# Optional notarization (app-specific password from appleid.apple.com):
# APPLE_ID=""
# APPLE_PASSWORD=""
# APPLE_TEAM_ID=""
