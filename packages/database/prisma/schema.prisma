datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  // Emit OpenTelemetry spans for queries so DB work shows up as child spans
  // under the request/tRPC trace. Requires `@prisma/instrumentation` registered
  // in the OTel setup (apps/web/lib/observability/otel.ts). Re-run
  // `pnpm db:generate` after changing this block.
  previewFeatures = ["tracing"]
}

// ─── USERS & AUTH ───────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  supabaseAuthId String?  @unique
  email          String   @unique
  name           String
  passwordHash   String? // deprecated — kept for migration, Supabase Auth handles passwords
  avatarUrl      String?
  role           String   @default("MEMBER")
  githubUserId   Int?     @unique
  githubLogin    String?  @unique
  /// Slack user id (e.g. `U01ABC...`) — set when the user links their Slack
  /// identity to OmniTool so inbound `app_mention` events can resolve to a
  /// concrete OmniTool user.
  slackUserId    String?  @unique
  /// Back-pointer to this user's auto-created PERSONAL teamspace. Set by the
  /// JIT user-sync path in `auth()`. Nullable during the migration window.
  personalTeamId String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  emailVerified DateTime?

  teamMembers          TeamMember[]
  personalTeam         Team?                 @relation("PersonalTeam", fields: [personalTeamId], references: [id])
  assignedTasks        Task[]                @relation("TaskAssignee")
  createdTasks         Task[]                @relation("TaskCreator")
  assignedIssues       Issue[]               @relation("IssueAssignee")
  reportedIssues       Issue[]               @relation("IssueReporter")
  notes                Note[]
  noteVersions         NoteVersion[]
  timeEntries          TimeEntry[]
  aiConversations      AIConversation[]
  comments             Comment[]
  connectedAccounts    ConnectedAccount[]
  githubImports        GitHubImportLog[]
  dailyCodingSummaries DailyCodingSummary[]
  invitationsSent      TeamInvitation[]      @relation("InvitationsSent")
  slackInstalls        SlackTeamInstall[]
  personalAccessTokens PersonalAccessToken[]
  notePreference       UserNotePreference?
  newsDigests          NewsDigest[]
  agentHandoffs        AgentHandoff[]
  mentionsReceived     NoteMention[]         @relation("MentionedUser")
  mentionsSent         NoteMention[]         @relation("MentionAuthor")
  noteComments         NoteComment[]         @relation("NoteCommentAuthor")
  noteCommentReads     NoteCommentRead[]

  @@map("users")
}

// ─── TEAMS ──────────────────────────────────────────────────

model Team {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  description      String?
  /// "PERSONAL" (auto-created per user, hidden from team-management UIs)
  /// or "TEAM" (multi-member organization). Defaults to TEAM for backwards
  /// compatibility with existing rows.
  kind             String    @default("TEAM")
  ownerId          String?
  /// Optional avatar/logo. For GitHub-imported teams, set to the org's
  /// avatar URL on import; for personal-imported teams, the user's avatar.
  /// User-created teams leave this null (UI falls back to colored initial).
  avatarUrl        String?
  githubOrgId      Int?      @unique
  githubOrgLogin   String?   @unique
  githubImportedAt DateTime?
  /// "full" (default) emits issue/note details inline in Slack replies;
  /// "task-link-only" replies with just a deep link to the OmniTool record.
  /// Mirrors the Codex enterprise least-noise toggle (research §12.2).
  slackReplyMode   String    @default("full")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  members              TeamMember[]
  projects             Project[]
  dailyCodingSummaries DailyCodingSummary[]
  invitations          TeamInvitation[]
  notes                Note[]
  slackInstalls        SlackTeamInstall[]
  personalForUser      User?                @relation("PersonalTeam")

  @@index([kind])
  @@map("teams")
}

model TeamMember {
  id       String   @id @default(cuid())
  userId   String
  teamId   String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("team_members")
}

model TeamInvitation {
  id         String    @id @default(cuid())
  teamId     String
  email      String
  role       String    @default("MEMBER")
  invitedBy  String
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  team    Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter User @relation("InvitationsSent", fields: [invitedBy], references: [id])

  @@unique([teamId, email])
  @@map("team_invitations")
}

// ─── PROJECTS & TASKS ───────────────────────────────────────

model Project {
  id                 String    @id @default(cuid())
  name               String
  slug               String    @unique
  description        String?
  status             String    @default("ACTIVE")
  teamId             String
  githubRepoId       Int?
  githubRepoFullName String?
  githubImportedAt   DateTime?
  startDate          DateTime?
  targetDate         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  team               Team                @relation(fields: [teamId], references: [id])
  tasks              Task[]
  issues             Issue[]
  metrics            PerformanceMetric[]
  linkedNote         Note?
  githubPullRequests GitHubPullRequest[]
  githubCommits      GitHubCommit[]
  agentHandoffs      AgentHandoff[]

  @@map("projects")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("TODO")
  priority    String    @default("MEDIUM")
  storyPoints Int?
  projectId   String
  assigneeId  String?
  creatorId   String
  parentId    String?
  dueDate     DateTime?
  firstStartedAt DateTime?
  completedAt DateTime?
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User?       @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator     User        @relation("TaskCreator", fields: [creatorId], references: [id])
  parent      Task?       @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks    Task[]      @relation("TaskSubtasks")
  timeEntries TimeEntry[]
  labels      Label[]     @relation("TaskLabels")
  comments    Comment[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([creatorId])
  @@map("tasks")
}

// ─── ISSUES ─────────────────────────────────────────────────

model Issue {
  id                 String    @id @default(cuid())
  identifier         String    @unique
  title              String
  description        String?
  status             String    @default("OPEN")
  priority           String    @default("MEDIUM")
  severity           String?
  projectId          String
  assigneeId         String?
  reporterId         String
  dueDate            DateTime?
  resolvedAt         DateTime?
  githubIssueNumber  Int?
  githubRepoFullName String?
  linearIssueId      String?   @unique
  linearTeamKey      String?
  linearIdentifier   String?
  linearSyncedAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?     @relation("IssueAssignee", fields: [assigneeId], references: [id])
  reporter User      @relation("IssueReporter", fields: [reporterId], references: [id])
  labels   Label[]   @relation("IssueLabels")
  comments Comment[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([reporterId])
  @@index([githubRepoFullName, githubIssueNumber])
  @@map("issues")
}

// ─── NOTES & IDEAS ──────────────────────────────────────────

model Note {
  id              String    @id @default(cuid())
  title           String
  emoji           String?   @db.VarChar(16)
  content         String?
  contentText     String    @default("")
  blocks          Json?
  authorId        String
  /// Teamspace owning this note. Nullable during the backfill window; the
  /// application code treats a null teamId as "belongs to author's personal
  /// teamspace" until the migration script populates the column.
  teamId          String?
  parentId        String?
  position        Int       @default(0)
  isPinned        Boolean   @default(false)
  notionPageId    String?
  notionUrl       String?
  linkedProjectId String?   @unique
  isAutoCreated   Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  /// Full-text search vector: a DB-managed GENERATED column populated from
  /// title (weight A) + contentText (weight B), defined in
  /// supabase/migrations/20260506_fulltext_search.sql. Modeled as Unsupported
  /// so `prisma db push` / `migrate` never tries to DROP it (Prisma can't
  /// express a GENERATED column). Read only via raw SQL in note.searchNotes.
  search_vector   Unsupported("tsvector")?

  author          User              @relation(fields: [authorId], references: [id])
  team            Team?             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  parent          Note?             @relation("NoteTree", fields: [parentId], references: [id], onDelete: Cascade)
  children        Note[]            @relation("NoteTree")
  tags            Tag[]             @relation("NoteTags")
  aiConversations AIConversation[]
  linkedProject   Project?          @relation(fields: [linkedProjectId], references: [id], onDelete: SetNull)
  versions        NoteVersion[]
  outboundLinks   NoteLink[]        @relation("NoteLinkSource")
  inboundLinks    NoteLink[]        @relation("NoteLinkTarget")
  mentions        NoteMention[]
  comments        NoteComment[]
  commentReads    NoteCommentRead[]
  database        NoteDatabase?
  databaseRow     NoteDatabaseRow?
  shares          NoteShare[]

  @@index([authorId, parentId, position])
  @@index([teamId, parentId, position])
  @@index([teamId, deletedAt])
  @@index([teamId])
  @@index([authorId])
  @@index([notionPageId])
  @@index([teamId, notionPageId])
  @@index([linkedProjectId])
  @@index([authorId, deletedAt])
  @@index([search_vector], type: Gin, map: "idx_notes_search_vector")
  @@map("notes")
}

// ─── NOTE BIDIRECTIONAL LINKS ───────────────────────────────

model NoteLink {
  id           String   @id @default(cuid())
  sourceNoteId String
  targetNoteId String
  /// "mention" (inline @-chip) or "embed" (full block)
  kind         String   @default("mention")
  /// Block id within the source document where the link appears (best-effort)
  blockId      String?
  createdAt    DateTime @default(now())

  source Note @relation("NoteLinkSource", fields: [sourceNoteId], references: [id], onDelete: Cascade)
  target Note @relation("NoteLinkTarget", fields: [targetNoteId], references: [id], onDelete: Cascade)

  @@unique([sourceNoteId, targetNoteId, kind, blockId])
  @@index([targetNoteId])
  @@index([sourceNoteId])
  @@map("note_links")
}

// ─── NOTE MENTIONS (real @-person notifications) ────────────

model NoteMention {
  id              String    @id @default(cuid())
  noteId          String
  /// BlockNote block id where the @-chip was inserted, for jump-to.
  blockId         String?
  mentionedUserId String
  createdById     String
  createdAt       DateTime  @default(now())
  /// Set when the mentioned user opens / dismisses this mention.
  readAt          DateTime?

  note          Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  mentionedUser User @relation("MentionedUser", fields: [mentionedUserId], references: [id], onDelete: Cascade)
  createdBy     User @relation("MentionAuthor", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([mentionedUserId, readAt])
  @@index([noteId])
  @@map("note_mentions")
}

// ─── NOTE COMMENTS (per-note flat thread) ───────────────────

model NoteComment {
  id          String    @id @default(cuid())
  noteId      String
  authorId    String
  body        String
  /// Optional BlockNote block id this comment pins to (page-level if null).
  blockAnchor String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  note   Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  author User @relation("NoteCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt])
  @@map("note_comments")
}

model NoteCommentRead {
  userId     String
  noteId     String
  lastReadAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@id([userId, noteId])
  @@map("note_comment_reads")
}

// ─── NOTE VERSION HISTORY ───────────────────────────────────

model NoteVersion {
  id           String   @id @default(cuid())
  noteId       String
  editorUserId String
  source       String // "user-save" | "ai-edit" | "manual" | "restore"
  aiTool       String? // e.g. "appendToNote", "editSection" when source = "ai-edit"
  title        String
  blocks       Json
  contentText  String   @default("")
  sizeBytes    Int      @default(0)
  snapshotAt   DateTime @default(now())

  note   Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  editor User @relation(fields: [editorUserId], references: [id])

  @@index([noteId, snapshotAt])
  @@index([editorUserId])
  @@map("note_versions")
}

model Tag {
  id    String  @id @default(cuid())
  name  String  @unique
  color String?

  notes Note[] @relation("NoteTags")

  @@map("tags")
}

// ─── PERFORMANCE & TIME TRACKING ────────────────────────────

model TimeEntry {
  id          String    @id @default(cuid())
  userId      String
  taskId      String?
  description String?
  startTime   DateTime
  endTime     DateTime?
  duration    Int?
  billable    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User  @relation(fields: [userId], references: [id])
  task Task? @relation(fields: [taskId], references: [id])

  @@index([userId])
  @@index([taskId])
  @@map("time_entries")
}

model PerformanceMetric {
  id          String   @id @default(cuid())
  projectId   String
  metricType  String
  value       Float
  periodStart DateTime
  periodEnd   DateTime
  metadata    String?
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([projectId, metricType, periodStart])
  @@map("performance_metrics")
}

// ─── AI CONVERSATIONS ───────────────────────────────────────

model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  agentType String
  noteId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id])
  note     Note?       @relation(fields: [noteId], references: [id], onDelete: SetNull)
  messages AIMessage[]

  @@index([noteId])
  @@index([userId])
  @@map("ai_conversations")
}

model AIMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  toolCalls      String?
  toolResults    String?
  tokenCount     Int?
  createdAt      DateTime @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("ai_messages")
}

// ─── INTEGRATIONS ───────────────────────────────────────────

model ConnectedAccount {
  id                    String    @id @default(cuid())
  userId                String
  provider              String
  providerAccountId     String
  encryptedAccessToken  String
  encryptedRefreshToken String?
  tokenExpiry           DateTime?
  scopes                String    @default("")
  metadata              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("connected_accounts")
}

// ─── SHARED ─────────────────────────────────────────────────

model Label {
  id    String @id @default(cuid())
  name  String @unique
  color String

  tasks  Task[]  @relation("TaskLabels")
  issues Issue[] @relation("IssueLabels")

  @@map("labels")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  taskId    String?
  issueId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User   @relation(fields: [authorId], references: [id])
  task   Task?  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  issue  Issue? @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([issueId])
  @@index([authorId])
  @@map("comments")
}

// ─── GITHUB IMPORT ──────────────────────────────────────────

model GitHubImportLog {
  id               String    @id @default(cuid())
  userId           String
  githubOrgId      Int
  githubOrgLogin   String
  teamId           String
  projectsImported Int       @default(0)
  membersImported  Int       @default(0)
  membersSkipped   Int       @default(0)
  status           String    @default("PENDING")
  errorMessage     String?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  user User @relation(fields: [userId], references: [id])

  @@map("github_import_logs")
}

// ─── DAILY CODING SUMMARIES ─────────────────────────────────

model DailyCodingSummary {
  id             String   @id @default(cuid())
  userId         String
  teamId         String?
  date           String // "YYYY-MM-DD" in user's local timezone
  timezone       String // IANA timezone name
  sessionCount   Int
  totalMessages  Int
  sources        String // JSON array of source labels
  title          String
  overview       String   @db.Text
  keyTopics      String // JSON array
  actionItems    String // JSON array
  risks          String // JSON array
  perSessionMeta String?  @db.Text // JSON [{id, source, title, messageCount, project}]
  modelUsed      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([userId, date])
  @@index([teamId, date])
  @@map("daily_coding_summaries")
}

// ─── ACTIVITY EVENTS & ENTITY LINKS ─────────────────────────

model ActivityEvent {
  id          String   @id @default(cuid())
  type        String // e.g. "task.created", "issue.closed", "note.updated", "github.pr.merged"
  actorId     String?
  actorType   String   @default("user") // "user" | "system" | "integration"
  teamId      String?
  projectId   String?
  subjectType String // "task" | "issue" | "note" | "pr" | "commit" | "handoff"
  subjectId   String
  payload     Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([teamId, createdAt])
  @@index([projectId, createdAt])
  @@index([subjectType, subjectId])
  @@index([actorId, createdAt])
  @@map("activity_events")
}

model EntityLink {
  id         String   @id @default(cuid())
  sourceType String // "task" | "issue" | "note" | "github_pr" | "github_issue" | "handoff"
  sourceId   String
  targetType String
  targetId   String
  linkType   String // "references" | "implements" | "caused_by" | "blocks"
  metadata   Json?
  createdBy  String?
  createdAt  DateTime @default(now())

  @@unique([sourceType, sourceId, targetType, targetId, linkType])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@map("entity_links")
}

// ─── GITHUB SYNC (MIRROR TABLES) ────────────────────────────

model GitHubPullRequest {
  id                 String    @id @default(cuid())
  projectId          String
  githubPrId         Int
  githubRepoFullName String
  number             Int
  title              String
  state              String // "open" | "closed" | "merged"
  authorGithubLogin  String?
  authorUserId       String?
  headBranch         String
  baseBranch         String
  body               String?
  mergedAt           DateTime?
  closedAt           DateTime?
  createdAt          DateTime
  updatedAt          DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([githubRepoFullName, number])
  @@index([projectId, state])
  @@index([authorUserId])
  @@map("github_pull_requests")
}

model GitHubCommit {
  id                String   @id @default(cuid())
  projectId         String
  sha               String
  message           String
  authorGithubLogin String?
  authorUserId      String?
  timestamp         DateTime
  additions         Int?
  deletions         Int?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sha])
  @@index([authorUserId, timestamp])
  @@map("github_commits")
}

// ─── NEWS DIGEST ────────────────────────────────────────────

model NewsDigest {
  id        String    @id @default(cuid())
  userId    String
  date      String // "YYYY-MM-DD"
  topics    Json // extracted topics used for search
  articles  Json // [{title, url, snippet, topic, summary}]
  synthesis String    @db.Text
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("news_digests")
}

// ─── AGENT HANDOFFS ─────────────────────────────────────────

model AgentHandoff {
  id              String    @id @default(cuid())
  userId          String
  projectId       String
  title           String
  description     String    @db.Text
  contextPayload  Json // assembled from tasks, issues, notes, repo context
  agentProvider   String // "codex" | "claude-code"
  agentConfig     Json?
  status          String    @default("DRAFT") // DRAFT | SUBMITTED | IN_PROGRESS | AWAITING_REVIEW | APPROVED | REJECTED
  submittedAt     DateTime?
  externalRunId   String?
  externalUrl     String?
  resultSummary   String?   @db.Text
  resultArtifacts Json? // [{type: "patch"|"pr_url"|"file", content, path}]
  completedAt     DateTime?
  reviewedBy      String?
  reviewStatus    String? // "approved" | "rejected"
  reviewNotes     String?
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([projectId, status])
  @@map("agent_handoffs")
}

// ─── USER NOTE PREFERENCES ──────────────────────────────────

model UserNotePreference {
  userId                 String   @id
  autoCreateProjectNotes Boolean  @default(true)
  projectNotesParentId   String?
  viewMode               String   @default("cards")
  sortBy                 String   @default("updatedDesc")
  groupBy                String   @default("none")
  /// Last-selected teamspace lens on the /notes page. null = "All teamspaces".
  activeTeamspaceId      String?
  /// AI auto-sort: per-user "Inbox" section note for low-confidence captures
  /// (nullable = none yet; lazily created on first low-confidence capture).
  inboxNoteParentId         String?
  /// AI auto-sort: when true, large editor pastes prompt to auto-file into a note.
  autoSortPaste             Boolean  @default(false)
  /// AI auto-sort: char threshold above which an editor paste is treated "large".
  autoSortPasteThreshold    Int      @default(280)
  /// AI auto-sort: keep the pasted text in the current note vs moving it out.
  autoSortPasteKeepOriginal Boolean  @default(false)
  /// AI auto-sort: default teamspace for captures (null = active team, then personal).
  defaultCaptureTeamId      String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_note_preferences")
}

// ─── NOTE TEMPLATES ─────────────────────────────────────────

model NoteTemplate {
  id          String   @id @default(cuid())
  title       String
  emoji       String?  @db.VarChar(16)
  description String?
  blocks      Json
  contentText String   @default("")
  authorId    String
  teamId      String?
  isBuiltIn   Boolean  @default(false)
  category    String   @default("general")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teamId])
  @@index([authorId])
  @@map("note_templates")
}

// ─── NOTE DATABASES (Notion-style structured content) ───────

model NoteDatabase {
  id        String   @id @default(cuid())
  noteId    String   @unique
  schema    Json // PropertyDefinition[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  note  Note               @relation(fields: [noteId], references: [id], onDelete: Cascade)
  rows  NoteDatabaseRow[]
  views NoteDatabaseView[]

  @@map("note_databases")
}

model NoteDatabaseRow {
  id         String   @id @default(cuid())
  databaseId String
  noteId     String   @unique
  properties Json // {[propertyId]: value}
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  database NoteDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  note     Note         @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([databaseId, position])
  @@map("note_database_rows")
}

model NoteDatabaseView {
  id         String   @id @default(cuid())
  databaseId String
  name       String
  type       String // "table" | "board" | "calendar" | "gallery"
  config     Json // {filters, sorts, groupBy, hiddenProperties, propertyWidths, ...}
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  database NoteDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId, position])
  @@map("note_database_views")
}

// ─── NOTE SHARING ───────────────────────────────────────────

model NoteShare {
  id         String    @id @default(cuid())
  noteId     String
  targetType String // "user" | "team" | "link" | "public"
  targetId   String?
  token      String?   @unique
  role       String    @default("viewer") // "viewer" | "commenter" | "editor"
  expiresAt  DateTime?
  createdBy  String
  createdAt  DateTime  @default(now())

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, targetType, targetId])
  @@index([token])
  @@map("note_shares")
}

// ─── SYNCED BLOCKS ──────────────────────────────────────────

model SyncedBlock {
  id        String   @id @default(cuid())
  authorId  String
  teamId    String
  blocks    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId])
  @@map("synced_blocks")
}

// ─── WORKFLOW ENGINE ────────────────────────────────────────

model Workflow {
  id          String   @id @default(cuid())
  teamId      String
  name        String
  description String?
  status      String   @default("draft") // "active" | "paused" | "draft" | "archived"
  templateId  String?
  createdBy   String
  config      Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trigger WorkflowTrigger?
  steps   WorkflowStep[]
  runs    WorkflowRun[]

  @@index([teamId, status])
  @@index([createdBy])
  @@map("workflows")
}

model WorkflowTrigger {
  id          String    @id @default(cuid())
  workflowId  String    @unique
  kind        String // "event" | "schedule" | "manual" | "webhook"
  eventTypes  String? // JSON array of ActivityEventType values
  eventFilter Json?
  cronExpr    String?
  timezone    String?
  webhookSlug String?   @unique
  lastFiredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("workflow_triggers")
}

model WorkflowStep {
  id         String   @id @default(cuid())
  workflowId String
  position   Int
  kind       String // "agent" | "action" | "condition" | "approval" | "delay" | "parallel"
  config     Json
  label      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, position])
  @@index([workflowId])
  @@map("workflow_steps")
}

model WorkflowRun {
  id           String    @id @default(cuid())
  workflowId   String
  status       String    @default("pending") // "pending"|"running"|"completed"|"failed"|"waiting_approval"|"cancelled"
  triggerData  Json?
  currentStep  Int       @default(0)
  stepResults  Json      @default("{}")
  context      Json      @default("{}")
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  error        String?
  approvalData Json?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, status])
  @@index([status, startedAt])
  @@map("workflow_runs")
}

// ─── SLACK NOTIFICATION CONFIG ──────────────────────────────

model SlackNotificationConfig {
  id          String   @id @default(cuid())
  teamId      String
  channelId   String
  channelName String
  eventTypes  String // JSON array of ActivityEventType values
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([teamId, channelId])
  @@map("slack_notification_configs")
}

// ─── SLACK WORKSPACE INSTALL ────────────────────────────────

/**
 * Per-Slack-workspace install record. Captures the bot token + identifying
 * metadata when an OmniTool user installs the Slack app in a workspace via
 * the OAuth callback. Enables inbound `app_mention` dispatch by mapping
 * `payload.team_id` → workspace install → bot token.
 */
model SlackTeamInstall {
  id                String   @id @default(cuid())
  teamId            String   @unique // Slack workspace ID (T...)
  teamName          String
  botUserId         String
  encryptedBotToken String
  installerUserId   String
  /// Optional OmniTool team association — set when the install should be
  /// scoped to a specific OmniTool teamspace.
  workspaceId       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  installer User  @relation(fields: [installerUserId], references: [id], onDelete: Cascade)
  workspace Team? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([installerUserId])
  @@index([workspaceId])
  @@map("slack_team_installs")
}

// ─── PERSONAL ACCESS TOKENS (MCP / API) ─────────────────────

/**
 * Long-lived bearer tokens used by external coding agents (Cursor, Claude
 * Code, Codex) to authenticate with OmniTool's MCP server. Tokens are
 * generated as random hex, shown to the user once on creation, and stored
 * only as a SHA-256 hash. Revocation is soft (revokedAt) so audit history
 * is preserved.
 */
model PersonalAccessToken {
  id          String    @id @default(cuid())
  userId      String
  name        String
  hashedToken String    @unique
  /// JSON array of scope strings (currently informational; tools are gated
  /// by the user identity that owns the token).
  scopes      String    @default("[]")
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("personal_access_tokens")
}
