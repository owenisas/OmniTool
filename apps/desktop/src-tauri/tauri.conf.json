{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OmniTool",
  "version": "0.0.1",
  "identifier": "dev.omnitool.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "node ../../scripts/desktop-before-build.mjs",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../app-shell"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "deb", "appimage"],
    "createUpdaterArtifacts": true,
    "publisher": "Reunify",
    "category": "Productivity",
    "shortDescription": "Internal productivity and performance tracking app",
    "longDescription": "OmniTool is an internal app for performance tracking, issue tracking, notes, and AI agents.",
    "resources": ["resources/"]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Reunify/OmniTool/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    },
    "deep-link": {
      "desktop": {
        "schemes": ["omnitool"]
      }
    }
  }
}
