{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "passThroughEnv": [
        "APPLE_SIGNING_IDENTITY",
        "APPLE_ID",
        "APPLE_PASSWORD",
        "APPLE_TEAM_ID",
        "APPLE_CERTIFICATE",
        "APPLE_CERTIFICATE_PASSWORD"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "db:push": { "cache": false },
    "db:migrate": { "cache": false },
    "db:deploy": { "cache": false },
    "db:seed": { "cache": false },
    "db:studio": { "cache": false },
    "db:generate": { "cache": false },
    "clean": { "cache": false }
  }
}
